{
  "name": "smarthireai",
  "version": "1.0.0",
  "scripts": {
    "install-all": "npm install && npm install --prefix client --include=dev && npm install --prefix server",
    "build-client": "npm run build --prefix client",
    "build": "npm install --prefix client --include=dev && npm run build --prefix client",
    "start": "node server/server.js",
    "server": "npm run dev --prefix server",
    "client": "npm run dev --prefix client",
    "dev": "concurrently \"npm run server\" \"npm run client\""
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.17.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.11",
    "pdf-parse": "^1.1.4",
    "react-router-dom": "^7.17.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
